# Telegram Bot Configuration
# Получите токен от @BotFather в Telegram
# Формат: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890
TELEGRAM_BOT_TOKEN=8704602172:AAE5yOb2Y_y3XqCICKi9q8ZjCnhUlIG7h84

# Webhook URL для получения обновлений от Telegram
# Формат: https://your-domain.com/tg/your-secret-path
# Важно: URL должен содержать /tg/ в пути!
# Используется только если POLLING_MODE=0 (по умолчанию)
TELEGRAM_WEBHOOK_URL=https://skoring-artem1990amvera.io/tg/1234567890

# Режим работы бота
# 0 или не указано - webhook режим (рекомендуется для продакшена)
# 1 - polling режим (для локальной разработки или когда webhook недоступен)
POLLING_MODE=0

# DaData API Credentials
# Получите на https://dadata.ru/profile/#info
DADATA_API_KEY=4de1d58c33dc23fe540e123f6714a6c5fd2a87df
DADATA_SECRET_KEY=828b59564c78aee748c685d433802decdf7e8d59

# Timeout для запросов к DaData API (в секундах)
DADATA_TIMEOUT=5.0

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Порт для сервера (используется в server.py)
# По умолчанию 8000, в Amvera/Render автоматически задается
PORT=8000

# Задержка старта Telegram бота (в секундах)
# Может быть полезно при деплое, чтобы дождаться инициализации других сервисов
TELEGRAM_STARTUP_DELAY_SECONDS=0
